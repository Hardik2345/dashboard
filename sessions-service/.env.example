# Sessions service observability.
SENTRY_DSN=replace-with-sessions-service-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=replace-with-release-or-git-sha
SENTRY_TRACES_SAMPLE_RATE=0

METRICS_ENABLED=true
METRICS_AUTH_TOKEN=replace-with-same-token-as-root-env

# Optional explicit service label. Defaults to sessions-service.
SERVICE_NAME=sessions-service

# Optional health-monitor application event reporting.
HEALTH_MONITOR_EVENTS_URL=http://health-monitor-service:4015/events
HEALTH_MONITOR_EVENT_TIMEOUT_MS=5000
HEALTH_MONITOR_SUCCESS_CACHE_TTL_MS=1800000
HEALTH_MONITOR_EVENT_PAYLOAD_MAX_LENGTH=2000
HEALTH_MONITOR_EVENT_HEADER_VALUE_MAX_LENGTH=300
