# Shared production env placeholders.
# Copy the relevant values into the real root .env used by docker-compose.

# Shared metrics scrape token. Use one long random value and keep it identical
# across root .env and every backend service .env.
METRICS_ENABLED=true
METRICS_AUTH_TOKEN=eplace-with-long-random-token

# Grafana Cloud Prometheus remote-write credentials.
# Find these in Grafana Cloud -> Prometheus -> Details / Send metrics.
GRAFANA_CLOUD_PROMETHEUS_REMOTE_WRITE_URL=https://prometheus-prod-xx.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=replace-with-prometheus-instance-id
GRAFANA_CLOUD_API_TOKEN=replace-with-grafana-cloud-api-token

# Grafana Cloud Loki credentials.
# Find these in Grafana Cloud -> Loki -> Details / Send logs.
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-xx.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=replace-with-loki-instance-id

# Grafana Cloud API for provisioning alert rules.
# This token is different from the metrics/logs write token above.
GRAFANA_STACK_URL=https://your-stack.grafana.net
GRAFANA_SERVICE_ACCOUNT_TOKEN=replace-with-grafana-service-account-token
GRAFANA_PROMETHEUS_DATASOURCE_UID=
GRAFANA_ORG_ID=1
GRAFANA_ALERT_FOLDER_UID=production-core
GRAFANA_ALERT_FOLDER_TITLE=Production Core
GRAFANA_INCLUDE_WARNING_ALERTS=false

# Release version shown in Sentry events. Set this to the git SHA, image tag,
# or deployment version during deploy.
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=replace-with-release-or-git-sha

# Shared health monitor registration target used by service startup hooks.
HEALTH_MONITOR_REGISTER_URL=http://health-monitor-service:4015/register

# Health monitor service runtime.
HEALTH_MONITOR_PORT=4015
HEALTH_MONITOR_MONGO_URI=mongodb://localhost:27017/datum_health_monitor
HEALTH_MONITOR_MONGO_DB=api_monitor
HEALTH_RETRY_COUNT=2
HEALTH_RETRY_INTERVAL_MS=5000
DEFAULT_ENDPOINT_INTERVAL_SECONDS=300
REGISTRATION_VALIDATION_INTERVAL_HOURS=3
HEALTH_MONITOR_REQUEST_TIMEOUT_MS=10000
RESPONSE_SUMMARY_MAX_LENGTH=500
EVIDENCE_COLLECTION_TIMEOUT_MS=10000
API_RESPONSE_EVIDENCE_TIMEOUT_MS=10000
HEALTH_PROBE_TIMEOUT_MS=10000
DEPENDENCY_CHECK_TIMEOUT_MS=10000
DOCKER_LOG_TIMEOUT_MS=10000
HEALTH_LOG_LINES=100
EMAIL_LOG_TRUNCATION_LENGTH=1000
DOCKER_SOCKET_PATH=/var/run/docker.sock
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_EMAIL=alerts@example.com
GMAIL_APP_PASSWORD=replace-with-gmail-app-password
ALERT_RECIPIENTS=ops@example.com,engineering@example.com
INCIDENT_EMAIL_SUBJECT_PREFIX=[Datum Health]
LOG_LEVEL=info
