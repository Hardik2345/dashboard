# Analytics service observability.
SENTRY_DSN=replace-with-analytics-service-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=replace-with-release-or-git-sha
SENTRY_TRACES_SAMPLE_RATE=0

METRICS_ENABLED=true
METRICS_AUTH_TOKEN=replace-with-same-token-as-root-env

# Optional explicit service label. Defaults to analytics-service.
SERVICE_NAME=analytics-service
SESSIONS_MONGO_URI=

# Best-effort startup registration for the health monitor service.
HEALTH_MONITOR_REGISTER_URL=http://health-monitor-service:4015/register
