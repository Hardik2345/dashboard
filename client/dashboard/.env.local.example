# Frontend Sentry observability for Vite/Vercel.
# Add these to Vercel project environment variables for production builds,
# or copy to .env.local for local testing.

VITE_SENTRY_DSN=replace-with-dashboard-frontend-sentry-dsn
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=replace-with-release-or-git-sha
VITE_SENTRY_TRACES_SAMPLE_RATE=0
