HEALTH_MONITOR_PORT=4015
HEALTH_MONITOR_MONGO_URI=mongodb://localhost:27017/datum_health_monitor
HEALTH_MONITOR_MONGO_DB=datum_health_monitor
HEALTH_RETRY_COUNT=2
HEALTH_RETRY_INTERVAL_MS=5000
DEFAULT_ENDPOINT_INTERVAL_SECONDS=300
REGISTRATION_VALIDATION_INTERVAL_HOURS=3
HEALTH_MONITOR_REQUEST_TIMEOUT_MS=10000
RESPONSE_SUMMARY_MAX_LENGTH=500
EVIDENCE_COLLECTION_TIMEOUT_MS=10000
API_RESPONSE_EVIDENCE_TIMEOUT_MS=10000
HEALTH_PROBE_TIMEOUT_MS=10000
DEPENDENCY_CHECK_TIMEOUT_MS=10000
DOCKER_LOG_TIMEOUT_MS=10000
HEALTH_LOG_LINES=100
EMAIL_LOG_TRUNCATION_LENGTH=1000
APPLICATION_FAILURE_4XX_THRESHOLD_COUNT=5
APPLICATION_FAILURE_4XX_WINDOW_MS=600000
APPLICATION_FAILURE_REOPEN_COOLDOWN_MS=600000
APPLICATION_EVENT_PAYLOAD_MAX_LENGTH=2000
APPLICATION_EVENT_HEADER_VALUE_MAX_LENGTH=300
OPEN_INCIDENT_EMAIL_REMINDER_INTERVAL_MS=1800000
DOCKER_SOCKET_PATH=/var/run/docker.sock
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_EMAIL=alerts@example.com
GMAIL_APP_PASSWORD=app-password
ALERT_RECIPIENTS=ops@example.com,engineering@example.com
INCIDENT_EMAIL_SUBJECT_PREFIX=[Datum Health]
LOG_LEVEL=info
