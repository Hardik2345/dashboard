# Auth service observability.
SENTRY_DSN=placeholder-for-api-gateway-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=2026-05-28-1
SENTRY_TRACES_SAMPLE_RATE=0

METRICS_ENABLED=true
METRICS_AUTH_TOKEN=placeholder-for-api-gateway-metrics-auth-token

# Optional explicit service label. Defaults to api-gateway-auth.
SERVICE_NAME=api-gateway-auth

# Best-effort startup registration for the health monitor service.
HEALTH_MONITOR_REGISTER_URL=http://health-monitor-service:4015/register
